# Copy to a secure path, for example:
#   /etc/openclaw/openclaw-vault-resolver.env
# Set file permissions:
#   chmod 600 /etc/openclaw/openclaw-vault-resolver.env

OPENCLAW_VAULT_ADDR=http://127.0.0.1:8200
OPENCLAW_VAULT_ROLE_ID=replace-with-role-id
OPENCLAW_VAULT_SECRET_ID=replace-with-secret-id
OPENCLAW_VAULT_KV_MOUNT=secret
OPENCLAW_VAULT_KV_BASE_PATH=openclaw
OPENCLAW_VAULT_HTTP_TIMEOUT_MS=5000
# Optional cache fallback list: id=ttlMs,id2=ttlMs
# OPENCLAW_VAULT_CACHE_ALLOWLIST=providers/openai/apiKey=300000
